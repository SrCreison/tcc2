datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model GameRound {
  id                String   @id @default(uuid())
  serverSeed        String
  clientSeed        String
  nonce             Int
  betAmount         Float
  payout            Float
  isBonusBuy        Boolean
  totalScatters     Int
  history           Json     
  createdAt         DateTime @default(now())
}
