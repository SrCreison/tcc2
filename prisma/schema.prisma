generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb" // Ou "postgresql" se preferir
  url      = env("DATABASE_URL")
}

model GameRound {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  serverSeed        String
  clientSeed        String
  nonce             Int
  betAmount         Float
  payout            Float
  isBonusBuy        Boolean
  totalScatters     Int
  // Salvamos o histórico completo (cascatas) como JSON
  history           Json     
  createdAt         DateTime @default(now())
}
